{
  "version": "1.1.0",
  "status": "CURRENT",
  "membership_relation": "platform_shared.user_service_memberships",
  "immutable_key": [
    "user_id",
    "service_id"
  ],
  "revision": {
    "monotonic": true,
    "transition_audited": true
  },
  "client_writes": "DENIED",
  "activation": {
    "subject_source": "auth.uid()",
    "caller_supplied_user_id_allowed": false,
    "atomic_profile_creation": true,
    "idempotent": true
  },
  "hard_delete": "FORBIDDEN",
  "retirement_tombstone": "BLOCKED",
  "states": [
    "pending",
    "active",
    "suspended"
  ],
  "transitions": [
    {
      "from": null,
      "event": "global_signup_discovery",
      "to": "pending",
      "result": "CREATED_PENDING",
      "profile_effect": "NONE",
      "authorization": "system_account_creation"
    },
    {
      "from": null,
      "event": "authenticated_first_visit",
      "to": "active",
      "result": "ACTIVATED",
      "profile_effect": "CREATE_ATOMICALLY",
      "authorization": "authenticated_self"
    },
    {
      "from": "pending",
      "event": "authenticated_first_visit",
      "to": "active",
      "result": "ACTIVATED",
      "profile_effect": "CREATE_ATOMICALLY",
      "authorization": "authenticated_self"
    },
    {
      "from": "active",
      "event": "authenticated_first_visit",
      "to": "active",
      "result": "REUSED",
      "profile_effect": "REUSE",
      "authorization": "authenticated_self"
    },
    {
      "from": "active",
      "event": "suspend",
      "to": "suspended",
      "result": "SUSPENDED",
      "profile_effect": "PRESERVE",
      "authorization": "privileged_service_control"
    },
    {
      "from": "suspended",
      "event": "authenticated_first_visit",
      "to": "suspended",
      "result": "REJECTED_SUSPENDED",
      "profile_effect": "PRESERVE",
      "authorization": "authenticated_self"
    },
    {
      "from": "suspended",
      "event": "controlled_reinstate",
      "to": "active",
      "result": "REINSTATED",
      "profile_effect": "REUSE",
      "authorization": "privileged_service_control"
    }
  ],
  "invariants": {
    "idempotent": true,
    "activation_and_profile_atomic": true,
    "suspended_never_self_activates": true,
    "membership_is_not_entitlement": true
  }
}
