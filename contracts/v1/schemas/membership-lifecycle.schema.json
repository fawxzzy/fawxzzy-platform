{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fawxzzy:platform:schemas:v1:membership-lifecycle",
  "title": "Membership lifecycle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "status",
    "membership_relation",
    "immutable_key",
    "revision",
    "client_writes",
    "activation",
    "import_staging",
    "hard_delete",
    "retirement_tombstone",
    "states",
    "transitions",
    "invariants"
  ],
  "properties": {
    "version": {
      "const": "1.1.0"
    },
    "status": {
      "$ref": "urn:fawxzzy:platform:schemas:v1:common#/$defs/status"
    },
    "membership_relation": {
      "const": "platform_shared.user_service_memberships"
    },
    "immutable_key": {
      "const": [
        "user_id",
        "service_id"
      ]
    },
    "revision": {
      "const": {
        "monotonic": true,
        "transition_audited": true
      }
    },
    "client_writes": {
      "const": "DENIED"
    },
    "activation": {
      "const": {
        "subject_source": "auth.uid()",
        "caller_supplied_user_id_allowed": false,
        "atomic_profile_creation": true,
        "idempotent": true
      }
    },
    "import_staging": {
      "const": {
        "initial_state": "pending",
        "requires_auth_uid_derived_subject": true,
        "requires_new_target_session_on_origin": true,
        "requires_exact_product_profile_parity": true,
        "suspended_preserved": true
      }
    },
    "hard_delete": {
      "const": "FORBIDDEN"
    },
    "retirement_tombstone": {
      "const": "BLOCKED"
    },
    "states": {
      "const": [
        "pending",
        "active",
        "suspended"
      ]
    },
    "transitions": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "uniqueItems": true,
      "items": {
        "oneOf": [
          {
            "const": {
              "from": null,
              "event": "global_signup_discovery",
              "to": "pending",
              "result": "CREATED_PENDING",
              "profile_effect": "NONE",
              "authorization": "system_account_creation"
            }
          },
          {
            "const": {
              "from": null,
              "event": "authenticated_first_visit",
              "to": "active",
              "result": "ACTIVATED",
              "profile_effect": "CREATE_ATOMICALLY",
              "authorization": "authenticated_self"
            }
          },
          {
            "const": {
              "from": "pending",
              "event": "authenticated_first_visit",
              "to": "active",
              "result": "ACTIVATED",
              "profile_effect": "CREATE_ATOMICALLY",
              "authorization": "authenticated_self"
            }
          },
          {
            "const": {
              "from": "active",
              "event": "authenticated_first_visit",
              "to": "active",
              "result": "REUSED",
              "profile_effect": "REUSE",
              "authorization": "authenticated_self"
            }
          },
          {
            "const": {
              "from": "active",
              "event": "suspend",
              "to": "suspended",
              "result": "SUSPENDED",
              "profile_effect": "PRESERVE",
              "authorization": "privileged_service_control"
            }
          },
          {
            "const": {
              "from": "suspended",
              "event": "authenticated_first_visit",
              "to": "suspended",
              "result": "REJECTED_SUSPENDED",
              "profile_effect": "PRESERVE",
              "authorization": "authenticated_self"
            }
          },
          {
            "const": {
              "from": "suspended",
              "event": "controlled_reinstate",
              "to": "active",
              "result": "REINSTATED",
              "profile_effect": "REUSE",
              "authorization": "privileged_service_control"
            }
          }
        ]
      }
    },
    "invariants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "idempotent",
        "activation_and_profile_atomic",
        "suspended_never_self_activates",
        "membership_is_not_entitlement"
      ],
      "properties": {
        "idempotent": {
          "const": true
        },
        "activation_and_profile_atomic": {
          "const": true
        },
        "suspended_never_self_activates": {
          "const": true
        },
        "membership_is_not_entitlement": {
          "const": true
        }
      }
    }
  }
}
