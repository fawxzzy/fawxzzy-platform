{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fawxzzy:platform:schemas:v1:external-effects-disable-manifest",
  "title": "Restore clone external-effects disable manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "status",
    "backup_id",
    "project",
    "protected_projects",
    "restore_project_ref",
    "quarantine",
    "discordos",
    "effects",
    "manifest_sha256"
