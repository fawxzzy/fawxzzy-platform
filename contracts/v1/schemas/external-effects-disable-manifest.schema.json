    "discordos": {
      "$ref": "#/$defs/discordos"
    },
    "effects": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "unit",
          "status",
          "disabled",
          "evidence_digest",
          "evidence"
