        "properties": {
          "unit": {
            "enum": [
              "application_traffic",
              "auth_delivery_and_hooks",
              "cron",
              "database_network_calls",
              "dns",
              "edge_schedules",
              "environment_routing",
              "host_aliases",
              "queues",
              "realtime",
              "storage_events",
              "webhooks"
