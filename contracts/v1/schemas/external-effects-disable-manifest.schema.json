    "status": {
      "$ref": "urn:fawxzzy:platform:schemas:v1:common#/$defs/status"
    },
    "backup_id": {
      "type": "string",
      "pattern": "^FP-RECOVERY-BACKUP-[A-Z0-9-]+$"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "ref"
