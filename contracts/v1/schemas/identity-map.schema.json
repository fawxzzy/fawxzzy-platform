{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fawxzzy:platform:schemas:v1:identity-map",
  "title": "Identity map and provenance ledger contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "status",
    "rules",
    "entries",
    "ledger",
    "collision_summary"
  ],
  "properties": {
    "version": {
      "$ref": "urn:fawxzzy:platform:schemas:v1:common#/$defs/version"
    },
    "status": {
      "$ref": "urn:fawxzzy:platform:schemas:v1:common#/$defs/status"
    },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "one_target_auth_user_per_person",
        "normalized_email_is_not_adjudication",
        "automatic_source_merge_forbidden",
        "controlled_reauthentication_required"
      ],
      "properties": {
        "one_target_auth_user_per_person": {
          "const": true
        },
        "normalized_email_is_not_adjudication": {
          "const": true
        },
        "automatic_source_merge_forbidden": {
          "const": true
        },
        "controlled_reauthentication_required": {
          "const": true
        }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "source_user_id",
          "target_user_id",
          "rekey_version",
          "status"
        ],
        "properties": {
          "source": {
            "$ref": "urn:fawxzzy:platform:schemas:v1:common#/$defs/service"
          },
          "source_user_id": {
            "type": "string",
            "minLength": 1
          },
          "target_user_id": {
            "$ref": "urn:fawxzzy:platform:schemas:v1:common#/$defs/uuid"
          },
          "rekey_version": {
            "type": "integer",
            "minimum": 1
          },
          "status": {
            "$ref": "urn:fawxzzy:platform:schemas:v1:common#/$defs/status"
          }
        }
      }
    },
    "ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation",
        "append_only",
        "source_provenance_required",
        "semantic_cross_product_merge_forbidden"
      ],
      "properties": {
        "relation": {
          "const": "platform_private.source_identity_ledger"
        },
        "append_only": {
          "const": true
        },
        "source_provenance_required": {
          "const": true
        },
        "semantic_cross_product_merge_forbidden": {
          "const": true
        }
      }
    },
    "collision_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "sources",
        "count",
        "status",
        "pii_included"
      ],
      "properties": {
        "kind": {
          "const": "normalized_email"
        },
        "sources": {
          "const": [
            "fitness",
            "mazer"
          ]
        },
        "count": {
          "const": 1
        },
        "status": {
          "const": "OWNER_DECISION"
        },
        "pii_included": {
          "const": false
        }
      }
    }
  }
}
