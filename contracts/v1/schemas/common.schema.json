{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fawxzzy:platform:schemas:v1:common",
  "title": "Fawxzzy platform common definitions",
  "$defs": {
    "version": {
      "const": "1.0.0"
    },
    "status": {
      "enum": [
        "CURRENT",
        "REQUIRED",
        "OWNER_DECISION",
        "BLOCKED",
        "UNKNOWN",
        "NOT_APPLICABLE"
      ]
    },
    "project_ref": {
      "type": "string",
      "pattern": "^[a-z]{20}$"
    },
    "service": {
      "enum": [
        "discordos",
        "fitness",
        "mazer"
      ]
    },
    "membership_state": {
      "enum": [
        "pending",
        "active",
        "suspended"
      ]
    },
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "gate_operation": {
      "enum": [
        "target_writes",
        "data_import",
        "auth_import",
        "vercel_env_cutover",
        "production_deploy",
        "source_pause",
        "source_deletion"
      ]
    },
    "blocked_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "status",
        "reason"
      ],
      "properties": {
        "operation": {
          "$ref": "#/$defs/gate_operation"
        },
        "status": {
          "const": "BLOCKED"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
