{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fawxzzy:platform:schemas:v1:domain-session-contract",
  "title": "Domain, Auth policy, session, and SMTP contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "status",
    "security_session_decision_id",
    "origins",
    "domain_routing",
    "auth_configuration",
    "auth_policy",
    "provider_application_gate",
    "account_surfaces",
    "session_model",
    "smtp"
  ],
  "properties": {
    "version": {
      "const": "1.1.0"
    },
    "status": {
      "$ref": "urn:fawxzzy:platform:schemas:v1:common#/$defs/status"
    },
    "security_session_decision_id": {
      "const": "FP-MAN-012"
    },
    "origins": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "origin",
          "browser_session"
        ],
        "properties": {
          "role": {
            "enum": [
              "hub",
              "account",
              "fitness",
              "mazer"
            ]
          },
          "origin": {
            "type": "string",
            "pattern": "^https://(account\\.|fitness\\.|mazer\\.)?fawxzzy\\.com$"
          },
          "browser_session": {
            "enum": [
              "per_origin",
              "no_shared_session_assumption"
            ]
          }
        }
      }
    },
    "domain_routing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "www_redirect",
        "fitness_compatibility_redirect"
      ],
      "properties": {
        "www_redirect": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "destination",
            "status"
          ],
          "properties": {
            "source": {
              "const": "https://www.fawxzzy.com"
            },
            "destination": {
              "const": "https://fawxzzy.com"
            },
            "status": {
              "const": "REQUIRED"
            }
          }
        },
        "fitness_compatibility_redirect": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "destination",
            "status",
            "retirement_status"
          ],
          "properties": {
            "source": {
              "const": "https://fawxzzyfitness.com"
            },
            "destination": {
              "const": "https://fitness.fawxzzy.com"
            },
            "status": {
              "const": "REQUIRED"
            },
            "retirement_status": {
              "const": "BLOCKED"
            }
          }
        }
      }
    },
    "auth_configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "site_url",
        "exact_redirect_urls",
        "exact_recovery_url",
        "production_wildcards_allowed",
        "preview_redirects"
      ],
      "properties": {
        "site_url": {
          "const": "https://account.fawxzzy.com"
        },
        "exact_redirect_urls": {
          "const": [
            "https://account.fawxzzy.com/auth/callback",
            "https://account.fawxzzy.com/reset-password?recovery=1",
            "https://fitness.fawxzzy.com/auth/callback",
            "https://mazer.fawxzzy.com/auth/callback"
          ]
        },
        "exact_recovery_url": {
          "const": "https://account.fawxzzy.com/reset-password?recovery=1"
        },
        "production_wildcards_allowed": {
          "const": false
        },
        "preview_redirects": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "urls"
          ],
          "properties": {
            "status": {
              "const": "BLOCKED"
            },
            "urls": {
              "const": []
            }
          }
        }
      }
    },
    "auth_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "phase_one_method",
        "product_visible_sign_in_methods",
        "email_verification",
        "leaked_password_protection",
        "password_length",
        "deferred_methods",
        "account_change_security",
        "captcha",
        "passwordless_email",
        "mfa",
        "identity_linking",
        "jwt"
      ],
      "properties": {
        "decision_id": {
          "const": "FP-MAN-002"
        },
        "phase_one_method": {
          "const": "email_password"
        },
        "product_visible_sign_in_methods": {
          "const": [
            "email_password"
          ]
        },
        "email_verification": {
          "const": false
        },
        "leaked_password_protection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "enforcement",
            "status"
          ],
          "properties": {
            "enabled": {
              "const": true
            },
            "enforcement": {
              "const": "provider_native"
            },
            "status": {
              "const": "REQUIRED"
            }
          }
        },
        "password_length": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "minimum",
            "capacity"
          ],
          "properties": {
            "minimum": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "value",
                "enforcement",
                "status"
              ],
              "properties": {
                "value": {
                  "const": 10
                },
                "enforcement": {
                  "const": "provider_native"
                },
                "status": {
                  "const": "REQUIRED"
                }
              }
            },
            "capacity": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "decision_id",
                "status",
                "restrictive_app_cap_allowed",
                "minimum_supported_characters",
                "preferred_supported_characters_minimum",
                "never_truncate",
                "account_surface_enforcement",
                "provider_maximum_setting"
              ],
              "properties": {
                "decision_id": {
                  "const": "FP-MAN-008"
                },
                "status": {
                  "const": "CURRENT"
                },
                "restrictive_app_cap_allowed": {
                  "const": false
                },
                "minimum_supported_characters": {
                  "const": 64
                },
                "preferred_supported_characters_minimum": {
                  "const": 128
                },
                "never_truncate": {
                  "const": true
                },
                "account_surface_enforcement": {
                  "const": "accept_at_least_minimum_supported_characters"
                },
                "provider_maximum_setting": {
                  "const": "NOT_APPLICABLE"
                }
              }
            }
          }
        },
        "deferred_methods": {
          "const": [
            "social",
            "phone",
            "anonymous",
            "magic_link_only",
            "enforced_mfa"
          ]
        },
        "account_change_security": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "recent_authentication_for_password_changes",
            "current_password_for_signed_in_password_changes",
            "current_password_for_signed_in_email_changes",
            "secure_email_change",
            "native_hosted_current_password_for_email_change",
            "application_server_email_change_enforcement"
          ],
          "properties": {
            "recent_authentication_for_password_changes": {
              "const": "REQUIRED"
            },
            "current_password_for_signed_in_password_changes": {
              "const": "REQUIRED"
            },
            "current_password_for_signed_in_email_changes": {
              "const": "REQUIRED"
            },
            "secure_email_change": {
              "const": "REQUIRED"
            },
            "native_hosted_current_password_for_email_change": {
              "const": "UNKNOWN"
            },
            "application_server_email_change_enforcement": {
              "const": "REQUIRED"
            }
          }
        },
        "captcha": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "surfaces",
            "provider_class",
            "credential_installation",
            "live_configuration",
            "bypass_allowlist"
          ],
          "properties": {
            "status": {
              "const": "REQUIRED"
            },
            "surfaces": {
              "const": [
                "public_signup",
                "password_reset"
              ]
            },
            "provider_class": {
              "const": "UNKNOWN"
            },
            "credential_installation": {
              "const": "BLOCKED"
            },
            "live_configuration": {
              "const": "BLOCKED"
            },
            "bypass_allowlist": {
              "const": []
            }
          }
        },
        "passwordless_email": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "provider_toggle",
            "product_ui_exposure"
          ],
          "properties": {
            "provider_toggle": {
              "const": "UNKNOWN"
            },
            "product_ui_exposure": {
              "const": "BLOCKED"
            }
          }
        },
        "mfa": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "totp",
            "sms",
            "passkeys",
            "aal1_maximum_age_seconds"
          ],
          "properties": {
            "totp": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "available",
                "enrollment",
                "enforced"
              ],
              "properties": {
                "available": {
                  "const": true
                },
                "enrollment": {
                  "const": "optional"
                },
                "enforced": {
                  "const": false
                }
              }
            },
            "sms": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "status"
              ],
              "properties": {
                "status": {
                  "const": "BLOCKED"
                }
              }
            },
            "passkeys": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "status"
              ],
              "properties": {
                "status": {
                  "const": "BLOCKED"
                }
              }
            },
            "aal1_maximum_age_seconds": {
              "const": 900
            }
          }
        },
        "identity_linking": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "manual_client_linking",
            "privileged_reconciliation"
          ],
          "properties": {
            "manual_client_linking": {
              "const": false
            },
            "privileged_reconciliation": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "status",
                "verified_deterministic_identity_evidence",
                "username_only_matching_forbidden"
              ],
              "properties": {
                "status": {
                  "const": "REQUIRED"
                },
                "verified_deterministic_identity_evidence": {
                  "const": true
                },
                "username_only_matching_forbidden": {
                  "const": true
                }
              }
            }
          }
        },
        "jwt": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "expiry_seconds",
            "signing_key_class",
            "secret_material_allowed"
          ],
          "properties": {
            "expiry_seconds": {
              "const": "UNKNOWN"
            },
            "signing_key_class": {
              "const": "UNKNOWN"
            },
            "secret_material_allowed": {
              "const": false
            }
          }
        }
      }
    },
    "provider_application_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "apply_admitted",
        "requirements"
      ],
      "properties": {
        "status": {
          "const": "BLOCKED"
        },
        "apply_admitted": {
          "const": false
        },
        "requirements": {
          "const": [
            "fresh_target_preimage",
            "expected_state_mutation_authority",
            "exact_readback",
            "exact_rollback"
          ]
        }
      }
    },
    "account_surfaces": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_origin",
        "implementation_owner",
        "shared",
        "fitness",
        "mazer"
      ],
      "properties": {
        "owner_origin": {
          "const": "https://account.fawxzzy.com"
        },
        "implementation_owner": {
          "const": "FawxzzyWeb"
        },
        "shared": {
          "const": [
            {
              "surface": "sign_in",
              "status": "REQUIRED"
            },
            {
              "surface": "sign_out",
              "status": "REQUIRED"
            },
            {
              "surface": "account_updates",
              "status": "REQUIRED"
            },
            {
              "surface": "recovery",
              "status": "REQUIRED"
            }
          ]
        },
        "fitness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "branded_account_ux",
            "auth_backend",
            "central_recovery",
            "status"
          ],
          "properties": {
            "branded_account_ux": {
              "const": "preserved"
            },
            "auth_backend": {
              "const": "shared_target"
            },
            "central_recovery": {
              "const": true
            },
            "status": {
              "const": "REQUIRED"
            }
          }
        },
        "mazer": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "account_section_status",
            "username_slot_status",
            "auth_backend",
            "central_recovery"
          ],
          "properties": {
            "account_section_status": {
              "const": "REQUIRED"
            },
            "username_slot_status": {
              "const": "REQUIRED"
            },
            "auth_backend": {
              "const": "shared_target"
            },
            "central_recovery": {
              "const": true
            }
          }
        }
      }
    },
    "session_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "shared_auth_identity",
        "shared_database_contracts",
        "browser_sessions",
        "multiple_devices_allowed",
        "single_session_enforcement",
        "absolute_lifetime_seconds",
        "inactivity_timeout_seconds",
        "refresh_tokens",
        "cross_origin_sso"
      ],
      "properties": {
        "phase": {
          "const": 1
        },
        "shared_auth_identity": {
          "const": true
        },
        "shared_database_contracts": {
          "const": true
        },
        "browser_sessions": {
          "const": "per_origin"
        },
        "multiple_devices_allowed": {
          "const": true
        },
        "single_session_enforcement": {
          "const": false
        },
        "absolute_lifetime_seconds": {
          "const": 2592000
        },
        "inactivity_timeout_seconds": {
          "const": 604800
        },
        "refresh_tokens": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "compromise_detection",
            "rotation",
            "reuse_interval_seconds"
          ],
          "properties": {
            "compromise_detection": {
              "const": true
            },
            "rotation": {
              "const": true
            },
            "reuse_interval_seconds": {
              "const": 10
            }
          }
        },
        "cross_origin_sso": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "disposition",
            "allowed_future_mechanisms",
            "forbidden_mechanisms"
          ],
          "properties": {
            "status": {
              "const": "BLOCKED"
            },
            "disposition": {
              "const": "deferred_phase_two"
            },
            "allowed_future_mechanisms": {
              "const": [
                "pkce_code_exchange",
                "one_time_backend_exchange"
              ]
            },
            "forbidden_mechanisms": {
              "const": [
                "shared_refresh_cookies",
                "url_tokens"
              ]
            }
          }
        }
      }
    },
    "smtp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "production_custom_smtp",
        "provider_service",
        "sender_address",
        "secure_provider_domain_setup",
        "credentials_present",
        "live_configuration_allowed"
      ],
      "properties": {
        "decision_id": {
          "const": "FP-MAN-003"
        },
        "production_custom_smtp": {
          "const": "REQUIRED"
        },
        "provider_service": {
          "const": "operator_fawxzzy_com_google_gmail"
        },
        "sender_address": {
          "const": "no-reply@account.fawxzzy.com"
        },
        "secure_provider_domain_setup": {
          "const": "REQUIRED"
        },
        "credentials_present": {
          "const": false
        },
        "live_configuration_allowed": {
          "const": false
        }
      }
    }
  }
}
