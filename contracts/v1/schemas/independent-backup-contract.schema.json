{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fawxzzy:platform:schemas:v1:independent-backup-contract",
  "title": "Independent backup source contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "status",
    "decision_id",
    "lifecycle",
    "project",
    "policy",
    "coverage_units",
    "storage_body_boundary",
    "receipt_contract",
    "restore_quarantine",
    "execution_gates"
  ],
  "properties": {
    "version": {
      "$ref": "urn:fawxzzy:platform:schemas:v1:common#/$defs/version"
    },
    "status": {
      "const": "BLOCKED"
    },
    "decision_id": {
      "const": "FP-MAN-015"
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_state",
        "allowed_states",
        "execution_status"
      ],
      "properties": {
        "current_state": {
          "const": "SOURCE_READY"
        },
        "allowed_states": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/lifecycle_state"
          }
        },
        "execution_status": {
          "const": "BLOCKED"
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "ref",
        "plan",
        "compute"
      ],
      "properties": {
        "name": {
          "const": "Fawxzzy shared Supabase project"
        },
        "ref": {
          "const": "bxtcuhkotumitoqtrcej"
        },
        "plan": {
          "const": "Pro"
        },
        "compute": {
          "const": "Micro"
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "destination",
        "automation",
        "encryption",
        "schedule",
        "retention",
        "objectives",
        "cost",
        "provider_physical_backup_complement"
      ],
      "properties": {
        "destination": {
          "$ref": "#/$defs/destination"
        },
        "automation": {
          "$ref": "#/$defs/automation"
        },
        "encryption": {
          "$ref": "#/$defs/encryption"
        },
        "schedule": {
          "$ref": "#/$defs/schedule"
        },
        "retention": {
          "$ref": "#/$defs/retention"
        },
        "objectives": {
          "$ref": "#/$defs/objectives"
        },
        "cost": {
          "$ref": "#/$defs/cost"
        },
        "provider_physical_backup_complement": {
          "$ref": "#/$defs/physical_backup"
        }
      }
    },
    "coverage_units": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/coverage_unit"
      }
    },
    "storage_body_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "separate_recovery_contract_required_when_nonempty",
        "empty_denominator_status",
        "nonempty_without_current_receipt_status"
      ],
      "properties": {
        "separate_recovery_contract_required_when_nonempty": {
          "const": true
        },
        "empty_denominator_status": {
          "const": "NOT_APPLICABLE"
        },
        "nonempty_without_current_receipt_status": {
          "const": "BLOCKED"
        }
      }
    },
    "receipt_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_serialization",
        "digest_algorithm",
        "aggregate_only",
        "required_fields",
        "forbidden_classes"
      ],
      "properties": {
        "canonical_serialization": {
          "const": "lexicographic_object_keys_array_order_preserved_two_space_json_lf"
        },
        "digest_algorithm": {
          "const": "SHA-256"
        },
        "aggregate_only": {
          "const": true
        },
        "required_fields": {
          "type": "array",
          "minItems": 22,
          "maxItems": 22,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_classes": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "restore_quarantine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "external_effect_units",
        "all_disabled_before_readback",
        "application_traffic_allowed",
        "synthetic_canaries_only",
        "parity_units",
        "failed_clone_deletion_requires_separate_authority"
      ],
      "properties": {
        "external_effect_units": {
          "type": "array",
          "minItems": 12,
          "maxItems": 12,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/external_effect_unit"
          }
        },
        "all_disabled_before_readback": {
          "const": true
        },
        "application_traffic_allowed": {
          "const": false
        },
        "synthetic_canaries_only": {
          "const": true
        },
        "parity_units": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "auth",
              "catalog",
              "data",
              "security"
            ]
          }
        },
        "failed_clone_deletion_requires_separate_authority": {
          "const": true
        }
      }
    },
    "execution_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_setup",
        "credential_or_key_installation",
        "workflow_publication",
        "backup_generation_or_upload",
        "restore_rehearsal",
        "target_schema_auth_or_data_bootstrap",
        "cutover",
        "source_pause_or_deletion",
        "production"
      ],
      "properties": {
        "provider_setup": {
          "const": "BLOCKED"
        },
        "credential_or_key_installation": {
          "const": "BLOCKED"
        },
        "workflow_publication": {
          "const": "BLOCKED"
        },
        "backup_generation_or_upload": {
          "const": "BLOCKED"
        },
        "restore_rehearsal": {
          "const": "BLOCKED"
        },
        "target_schema_auth_or_data_bootstrap": {
          "const": "BLOCKED"
        },
        "cutover": {
          "const": "BLOCKED"
        },
        "source_pause_or_deletion": {
          "const": "BLOCKED"
        },
        "production": {
          "const": "BLOCKED"
        }
      }
    }
  },
  "$defs": {
    "lifecycle_state": {
      "enum": [
        "PLANNED",
        "SOURCE_READY",
        "EXECUTION_BLOCKED",
        "BACKUP_CURRENT",
        "RESTORE_REHEARSED",
        "DRIFTED"
      ]
    },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "region",
        "bucket_visibility",
        "object_lock_required",
        "retention_mode"
      ],
      "properties": {
        "provider": {
          "const": "Backblaze B2"
        },
        "region": {
          "const": "Canada East"
        },
        "bucket_visibility": {
          "const": "private"
        },
        "object_lock_required": {
          "const": true
        },
        "retention_mode": {
          "const": "COMPLIANCE"
        }
      }
    },
    "automation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheduler",
        "independent_watchdog_required",
        "workflow_publication_status"
      ],
      "properties": {
        "scheduler": {
          "const": "private_github_actions"
        },
        "independent_watchdog_required": {
          "const": true
        },
        "workflow_publication_status": {
          "const": "BLOCKED"
        }
      }
    },
    "encryption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_class",
        "streaming_before_upload",
        "persistent_plaintext_allowed",
        "automation_material",
        "offline_private_identity_count",
        "distinct_encrypted_media_required",
        "offsite_identity_count"
      ],
      "properties": {
        "tool_class": {
          "const": "age"
        },
        "streaming_before_upload": {
          "const": true
        },
        "persistent_plaintext_allowed": {
          "const": false
        },
        "automation_material": {
          "const": "public_recipients_only"
        },
        "offline_private_identity_count": {
          "const": 2
        },
        "distinct_encrypted_media_required": {
          "const": true
        },
        "offsite_identity_count": {
          "const": 1
        }
      }
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "full_export_interval_hours",
        "freshness_limit_hours"
      ],
      "properties": {
        "full_export_interval_hours": {
          "const": 6
        },
        "freshness_limit_hours": {
          "const": 8
        }
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standard_days",
        "first_accepted_monthly_days"
      ],
      "properties": {
        "standard_days": {
          "const": 35
        },
        "first_accepted_monthly_days": {
          "const": 400
        }
      }
    },
    "objectives": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rpo_seconds",
        "quarantined_restore_data_plane_rto_seconds",
        "production_service_rto_status",
        "production_service_rto_seconds"
      ],
      "properties": {
        "rpo_seconds": {
          "const": 28800
        },
        "quarantined_restore_data_plane_rto_seconds": {
          "const": 43200
        },
        "production_service_rto_status": {
          "const": "UNKNOWN"
        },
        "production_service_rto_seconds": {
          "type": "null"
        }
      }
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_increment_usd_monthly",
        "warning_usd_monthly",
        "manual_approval_ceiling_usd_monthly",
        "budget_stop_control_required",
        "monthly_reporting_units"
      ],
      "properties": {
        "expected_increment_usd_monthly": {
          "const": 0
        },
        "warning_usd_monthly": {
          "const": 5
        },
        "manual_approval_ceiling_usd_monthly": {
          "const": 15
        },
        "budget_stop_control_required": {
          "const": true
        },
        "monthly_reporting_units": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "backup_freshness",
              "projected_cost",
              "runner_usage",
              "storage_growth"
            ]
          }
        }
      }
    },
    "physical_backup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "frequency",
        "retention_days",
        "storage_object_bodies_included"
      ],
      "properties": {
        "required": {
          "const": true
        },
        "frequency": {
          "const": "daily"
        },
        "retention_days": {
          "const": 7
        },
        "storage_object_bodies_included": {
          "const": false
        }
      }
    },
    "coverage_unit": {
      "enum": [
        "application_schemas_and_catalog",
        "roles_memberships_grants_and_default_acls",
        "migration_ledger",
        "application_data",
        "auth_identity_data_and_password_hashes",
        "auth_control_plane_metadata",
        "storage_metadata",
        "storage_object_bodies"
      ]
    },
    "external_effect_unit": {
      "enum": [
        "app_environment",
        "auth_delivery_and_hooks",
        "database_webhooks",
        "dns_and_aliases",
        "edge_schedules",
        "pg_cron",
        "pg_net",
        "queues",
        "realtime",
        "storage_events",
        "subscriptions",
        "wrappers"
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "utc_timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "safe_reference": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lifecycle_state",
        "project",
        "source_commit",
        "postgres_version",
        "tool_versions",
        "snapshot_at",
        "completed_at",
        "retention_until",
        "monthly_selection",
        "plaintext_sha256",
        "ciphertext_sha256",
        "migration_ledger_sha256",
        "manifest_sha256",
        "ciphertext_bytes",
        "destination_version",
        "encryption",
        "key_recipient_ids",
        "object_lock",
        "freshness",
        "coverage",
        "aggregate_counts",
        "owner_decision",
        "watchdog",
        "provider_physical_backup",
        "cost",
        "production_service_rto",
        "restore"
      ],
      "properties": {
        "lifecycle_state": {
          "enum": [
            "BACKUP_CURRENT",
            "RESTORE_REHEARSED"
          ]
        },
        "project": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "ref"
          ],
          "properties": {
            "name": {
              "const": "Fawxzzy shared Supabase project"
            },
            "ref": {
              "const": "bxtcuhkotumitoqtrcej"
            }
          }
        },
        "source_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "postgres_version": {
          "$ref": "#/$defs/safe_reference"
        },
        "tool_versions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": false,
          "patternProperties": {
            "^[a-z][a-z0-9_]{0,31}$": {
              "$ref": "#/$defs/safe_reference"
            }
          }
        },
        "snapshot_at": {
          "$ref": "#/$defs/utc_timestamp"
        },
        "completed_at": {
          "$ref": "#/$defs/utc_timestamp"
        },
        "retention_until": {
          "$ref": "#/$defs/utc_timestamp"
        },
        "monthly_selection": {
          "$ref": "#/$defs/monthly_selection"
        },
        "plaintext_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "ciphertext_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "migration_ledger_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "manifest_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "ciphertext_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "destination_version": {
          "$ref": "#/$defs/safe_reference"
        },
        "encryption": {
          "$ref": "#/$defs/receipt_encryption"
        },
        "key_recipient_ids": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/safe_reference"
          }
        },
        "object_lock": {
          "$ref": "#/$defs/receipt_object_lock"
        },
        "freshness": {
          "$ref": "#/$defs/receipt_freshness"
        },
        "coverage": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/receipt_coverage"
          }
        },
        "aggregate_counts": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": false,
          "patternProperties": {
            "^[a-z][a-z0-9_]{0,63}$": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "owner_decision": {
          "$ref": "#/$defs/receipt_owner_decision"
        },
        "watchdog": {
          "$ref": "#/$defs/receipt_watchdog"
        },
        "provider_physical_backup": {
          "$ref": "#/$defs/receipt_physical_backup"
        },
        "cost": {
          "$ref": "#/$defs/receipt_cost"
        },
        "production_service_rto": {
          "$ref": "#/$defs/receipt_production_rto"
        },
        "restore": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/receipt_restore"
            }
          ]
        }
      }
    },
    "monthly_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "month_utc",
        "accepted_exports_manifest_sha256"
      ],
      "properties": {
        "status": {
          "const": "CURRENT"
        },
        "month_utc": {
          "type": "string",
          "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
        },
        "accepted_exports_manifest_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "accepted_exports_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "status",
        "month_utc",
        "observed_at",
        "source_evidence_sha256",
        "entries"
      ],
      "properties": {
        "version": {
          "const": "1.0.0"
        },
        "status": {
          "const": "CURRENT"
        },
        "month_utc": {
          "type": "string",
          "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
        },
        "observed_at": {
          "$ref": "#/$defs/utc_timestamp"
        },
        "source_evidence_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/accepted_export_manifest_entry"
          }
        }
      }
    },
    "accepted_export_manifest_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completed_at",
        "destination_version",
        "ciphertext_sha256"
      ],
      "properties": {
        "completed_at": {
          "$ref": "#/$defs/utc_timestamp"
        },
        "destination_version": {
          "$ref": "#/$defs/safe_reference"
        },
        "ciphertext_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "receipt_encryption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "tool_class",
        "streaming_before_upload",
        "persistent_plaintext",
        "automation_material"
      ],
      "properties": {
        "status": {
          "const": "CURRENT"
        },
        "tool_class": {
          "const": "age"
        },
        "streaming_before_upload": {
          "const": true
        },
        "persistent_plaintext": {
          "const": false
        },
        "automation_material": {
          "const": "public_recipients_only"
        }
      }
    },
    "receipt_object_lock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "mode"
      ],
      "properties": {
        "status": {
          "const": "CURRENT"
        },
        "mode": {
          "const": "COMPLIANCE"
        }
      }
    },
    "receipt_freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "maximum_age_seconds"
      ],
      "properties": {
        "status": {
          "const": "CURRENT"
        },
        "maximum_age_seconds": {
          "const": 28800
        }
      }
    },
    "receipt_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit",
        "status",
        "aggregate_count",
        "private_digest",
        "body_recovery_receipt_status",
        "body_recovery_receipt_sha256"
      ],
      "properties": {
        "unit": {
          "$ref": "#/$defs/coverage_unit"
        },
        "status": {
          "enum": [
            "CURRENT",
            "NOT_APPLICABLE"
          ]
        },
        "aggregate_count": {
          "type": "integer",
          "minimum": 0
        },
        "private_digest": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/sha256"
            }
          ]
        },
        "body_recovery_receipt_status": {
          "enum": [
            "CURRENT",
            "NOT_APPLICABLE",
            "BLOCKED",
            null
          ]
        },
        "body_recovery_receipt_sha256": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/sha256"
            }
          ]
        }
      }
    },
    "receipt_owner_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "receipt_sha256",
        "accepted_at"
      ],
      "properties": {
        "decision_id": {
          "const": "FP-MAN-015"
        },
        "receipt_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "accepted_at": {
          "$ref": "#/$defs/utc_timestamp"
        }
      }
    },
    "receipt_watchdog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "independent_from_scheduler",
        "evidence_sha256"
      ],
      "properties": {
        "status": {
          "const": "CURRENT"
        },
        "independent_from_scheduler": {
          "const": true
        },
        "evidence_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "receipt_physical_backup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "retention_days",
        "evidence_sha256"
      ],
      "properties": {
        "status": {
          "const": "CURRENT"
        },
        "retention_days": {
          "const": 7
        },
        "evidence_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "receipt_cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budget_stop_control_status",
        "projected_usd_monthly",
        "monthly_report_status",
        "reported_units"
      ],
      "properties": {
        "budget_stop_control_status": {
          "const": "CURRENT"
        },
        "projected_usd_monthly": {
          "type": "number",
          "minimum": 0
        },
        "monthly_report_status": {
          "const": "CURRENT"
        },
        "reported_units": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "backup_freshness",
              "projected_cost",
              "runner_usage",
              "storage_growth"
            ]
          }
        }
      }
    },
    "receipt_production_rto": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "seconds"
      ],
      "properties": {
        "status": {
          "const": "UNKNOWN"
        },
        "seconds": {
          "type": "null"
        }
      }
    },
    "receipt_restore": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "traffic_released",
        "synthetic_canary_status",
        "external_effects",
        "parity",
        "failure_declared_at",
        "restore_started_at",
        "data_plane_ready_at",
        "measured_rpo_seconds",
        "measured_data_plane_rto_seconds",
        "failed_clone_deletion_authority_status"
      ],
      "properties": {
        "status": {
          "const": "CURRENT"
        },
        "traffic_released": {
          "const": false
        },
        "synthetic_canary_status": {
          "const": "CURRENT"
        },
        "external_effects": {
          "type": "array",
          "minItems": 12,
          "maxItems": 12,
          "items": {
            "$ref": "#/$defs/receipt_external_effect"
          }
        },
        "parity": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/receipt_parity"
          }
        },
        "failure_declared_at": {
          "$ref": "#/$defs/utc_timestamp"
        },
        "restore_started_at": {
          "$ref": "#/$defs/utc_timestamp"
        },
        "data_plane_ready_at": {
          "$ref": "#/$defs/utc_timestamp"
        },
        "measured_rpo_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "measured_data_plane_rto_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "failed_clone_deletion_authority_status": {
          "const": "BLOCKED"
        }
      }
    },
    "receipt_external_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit",
        "status",
        "disabled",
        "evidence_sha256"
      ],
      "properties": {
        "unit": {
          "$ref": "#/$defs/external_effect_unit"
        },
        "status": {
          "const": "CURRENT"
        },
        "disabled": {
          "const": true
        },
        "evidence_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "receipt_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit",
        "status",
        "aggregate_count",
        "private_digest"
      ],
      "properties": {
        "unit": {
          "enum": [
            "auth",
            "catalog",
            "data",
            "security"
          ]
        },
        "status": {
          "const": "CURRENT"
        },
        "aggregate_count": {
          "type": "integer",
          "minimum": 0
        },
        "private_digest": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
