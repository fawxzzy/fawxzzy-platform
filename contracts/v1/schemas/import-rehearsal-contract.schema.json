{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fawxzzy:platform:schemas:v1:import-rehearsal-contract",
  "title": "Shared Auth import and controlled reauthentication rehearsal contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "status",
    "lifecycle",
    "apply_admitted",
    "research_denominator_sha256",
    "source_anchors",
    "import_boundary",
    "collision_matrix",
    "staging_and_activation",
    "snapshot_and_idempotency",
    "synthetic_cohorts",
    "totp",
    "proofs",
    "preview_order",
    "receipt_boundary"
  ],
  "properties": {
    "version": {
      "const": "1.0.0"
    },
    "status": {
      "const": "CURRENT"
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_contract",
        "execution"
      ],
      "properties": {
        "source_contract": {
          "const": "SOURCE_READY"
        },
        "execution": {
          "const": "EXECUTION_BLOCKED"
        }
      }
    },
    "apply_admitted": {
      "const": false
    },
    "research_denominator_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "source_anchors": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "app",
          "commit"
        ],
        "properties": {
          "app": {
            "enum": [
              "platform",
              "web",
              "fitness",
              "mazer",
              "discordos"
            ]
          },
          "commit": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          }
        }
      }
    },
    "import_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adjudicated_canonical_humans_only",
        "provider_identities_require_accepted_source_mapping",
        "password_hashes",
        "excluded",
        "mutable_user_metadata"
      ],
      "properties": {
        "adjudicated_canonical_humans_only": {
          "const": true
        },
        "provider_identities_require_accepted_source_mapping": {
          "const": true
        },
        "password_hashes": {
          "const": "opaque_provider_compatible_never_serialized"
        },
        "excluded": {
          "type": "array",
          "minItems": 9,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "mutable_user_metadata": {
          "const": "presentation_only_never_authorization_or_linking"
        }
      }
    },
    "collision_matrix": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case",
          "outcome"
        ],
        "properties": {
          "case": {
            "type": "string"
          },
          "outcome": {
            "enum": [
              "IDEMPOTENT_RETRY",
              "ONE_TARGET_MAPPING",
              "QUARANTINE_PENDING_VERIFIED_EVIDENCE",
              "NEVER_MERGE",
              "NEVER_SUFFICIENT",
              "EXCLUDE_HUMAN_IMPORT",
              "FAIL_ENTIRE_BATCH"
            ]
          }
        }
      }
    },
    "staging_and_activation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "membership_initial_state",
        "activation_requirements",
        "suspended_remains_suspended",
        "fitness_profile_key",
        "mazer_profile_key",
        "fitness_numbers",
        "mazer_only_human_allocation",
        "discordos"
      ],
      "properties": {
        "membership_initial_state": {
          "const": "pending"
        },
        "activation_requirements": {
          "const": [
            "imported_non_quarantined_auth_identity",
            "accepted_immutable_mapping",
            "exact_product_profile_parity",
            "no_unresolved_identity_delta",
            "new_target_session_on_origin",
            "auth_uid_derived_subject",
            "current_recovery_and_rollback_evidence"
          ]
        },
        "suspended_remains_suspended": {
          "const": true
        },
        "fitness_profile_key": {
          "const": "fitness.profiles.id"
        },
        "mazer_profile_key": {
          "const": "mazer.mazer_profiles.user_id"
        },
        "fitness_numbers": {
          "const": "copy_exactly_never_reallocate"
        },
        "mazer_only_human_allocation": {
          "const": "BLOCKED_SEQUENCE_HIGH_WATER_GATE"
        },
        "discordos": {
          "const": "SERVICE_RUNTIME_NOT_HUMAN_COHORT"
        }
      }
    },
    "snapshot_and_idempotency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "S0",
        "S1",
        "diff_requires",
        "timestamps_alone_sufficient",
        "idempotency_key"
      ],
      "properties": {
        "S0": {
          "const": "AUTHORITATIVE_SNAPSHOT_REQUIRED"
        },
        "S1": {
          "const": "COMPLETE_REEXPORT_DIFF_REQUIRED"
        },
        "diff_requires": {
          "const": [
            "additions",
            "changes",
            "tombstones"
          ]
        },
        "timestamps_alone_sufficient": {
          "const": false
        },
        "idempotency_key": {
          "const": [
            "source_project",
            "relation",
            "source_key_digest",
            "row_digest",
            "transform_version"
          ]
        }
      }
    },
    "synthetic_cohorts": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "totp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "portability",
        "default",
        "proof"
      ],
      "properties": {
        "portability": {
          "const": "UNKNOWN"
        },
        "default": {
          "const": "REENROLL"
        },
        "proof": {
          "const": "SYNTHETIC_PORTABILITY_REHEARSAL_AND_ACTION_TIME_AGGREGATE_INVENTORY"
        }
      }
    },
    "proofs": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "preview_order": {
      "const": [
        "FawxzzyWeb_account_shell",
        "Mazer",
        "Fitness",
        "DiscordOS"
      ]
    },
    "receipt_boundary": {
      "const": [
        "aggregate_counts",
        "booleans",
        "ranges",
        "timestamps",
        "synthetic_cohort_labels",
        "one_way_digests"
      ]
    }
  }
}
