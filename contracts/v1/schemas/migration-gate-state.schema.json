{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:fawxzzy:platform:schemas:v1:migration-gate-state",
  "title": "Migration gate state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "status",
    "sql_generation",
    "semantic_cross_product_merges",
    "operation_gates",
    "required_evidence",
    "provider_canonical_provenance",
    "shared_auth_import_reauth_rehearsal",
    "app_data_transport",
    "app_data_adapters"
  ],
  "properties": {
    "version": {
      "const": "1.3.0"
    },
    "status": {
      "const": "BLOCKED"
    },
    "sql_generation": {
      "const": "next_separately_authorized_packet"
    },
    "semantic_cross_product_merges": {
      "const": "forbidden"
    },
    "shared_auth_import_reauth_rehearsal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "source_contract_lifecycle",
        "execution_lifecycle",
        "apply_admitted",
        "contract_path",
        "research_denominator_sha256"
      ],
      "properties": {
        "status": {
          "const": "CURRENT"
        },
        "source_contract_lifecycle": {
          "const": "SOURCE_READY"
        },
        "execution_lifecycle": {
          "const": "EXECUTION_BLOCKED"
        },
        "apply_admitted": {
          "const": false
        },
        "contract_path": {
          "const": "contracts/v1/auth/import-rehearsal-contract.json"
        },
        "research_denominator_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "app_data_transport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "source_contract_lifecycle",
        "execution_lifecycle",
        "apply_admitted",
        "contract_path",
        "receipt_path",
        "mutation_journal_contract_path",
        "research_denominator_sha256",
        "design_path_sha256",
        "dependency_status"
      ],
      "properties": {
        "status": {
          "const": "CURRENT"
        },
        "source_contract_lifecycle": {
          "const": "SOURCE_READY"
        },
        "execution_lifecycle": {
          "const": "EXECUTION_BLOCKED"
        },
        "apply_admitted": {
          "const": false
        },
        "contract_path": {
          "const": "contracts/v1/transport/app-data-transport-contract.json"
        },
        "receipt_path": {
          "const": "contracts/v1/transport/app-data-receipt.example.json"
        },
        "mutation_journal_contract_path": {
          "const": "contracts/v1/transport/app-data-mutation-journal-contract.json"
        },
        "research_denominator_sha256": {
          "const": "ae397c89afaf23231c2911d571d9799fabbb7a21196044f6679763e7515cf087"
        },
        "design_path_sha256": {
          "const": "f7554683cf3d9add36634afb6e6b543983d9968a600e05cf3ee885cc0a6f53ac"
        },
        "dependency_status": {
          "const": "BLOCKED"
        }
      }
    },
    "app_data_adapters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_order",
        "source_ready",
        "blocked",
        "mazer_contract_path",
        "mazer_relation_count",
        "fitness_contract_path",
        "fitness_relation_count",
        "all_adapters_ready",
        "execution_lifecycle",
        "apply_admitted"
      ],
      "properties": {
        "required_order": {
          "const": [
            "mazer",
            "fitness",
            "discordos"
          ]
        },
        "source_ready": {
          "const": [
            "mazer",
            "fitness"
          ]
        },
        "blocked": {
          "const": [
            "discordos"
          ]
        },
        "mazer_contract_path": {
          "const": "contracts/v1/transport/mazer-app-data-adapter-contract.json"
        },
        "mazer_relation_count": {
          "const": 4
        },
        "fitness_contract_path": {
          "const": "contracts/v1/transport/fitness-app-data-adapter-contract.json"
        },
        "fitness_relation_count": {
          "const": 27
        },
        "all_adapters_ready": {
          "const": false
        },
        "execution_lifecycle": {
          "const": "EXECUTION_BLOCKED"
        },
        "apply_admitted": {
          "const": false
        }
      }
    },
    "operation_gates": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "$ref": "urn:fawxzzy:platform:schemas:v1:common#/$defs/blocked_gate"
      }
    },
    "required_evidence": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "$ref": "urn:fawxzzy:platform:schemas:v1:common#/$defs/status"
          }
        }
      }
    },
    "provider_canonical_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "apply_admitted",
        "combined_provenance_sha256",
        "accepted_package",
        "sources",
        "effect_mappings_sha256",
        "effect_mappings"
      ],
      "properties": {
        "status": {
          "const": "CURRENT"
        },
        "apply_admitted": {
          "const": false
        },
        "combined_provenance_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "accepted_package": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "migration_count",
            "source_counts",
            "deterministic_package_sha256",
            "apply_admitted",
            "historical_path_rewrite_forbidden",
            "current_source_substitution_forbidden"
          ],
          "properties": {
            "migration_count": {
              "const": 122
            },
            "source_counts": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "discordos",
                "fitness",
                "mazer"
              ],
              "properties": {
                "discordos": {
                  "const": 17
                },
                "fitness": {
                  "const": 101
                },
                "mazer": {
                  "const": 4
                }
              }
            },
            "deterministic_package_sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "apply_admitted": {
              "const": false
            },
            "historical_path_rewrite_forbidden": {
              "const": true
            },
            "current_source_substitution_forbidden": {
              "const": true
            }
          }
        },
        "sources": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "app",
              "project_ref",
              "provider_ledger_migration_count",
              "current_git_migration_count",
              "current_git_canonicality",
              "complete_catalog_sha256"
            ],
            "properties": {
              "app": {
                "enum": [
                  "discordos",
                  "mazer"
                ]
              },
              "project_ref": {
                "type": "string",
                "pattern": "^[a-z0-9]{20}$"
              },
              "provider_ledger_migration_count": {
                "type": "integer",
                "minimum": 0
              },
              "current_git_migration_count": {
                "type": "integer",
                "minimum": 0
              },
              "current_git_canonicality": {
                "const": "not_provider_canonical"
              },
              "complete_catalog_sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              }
            }
          }
        },
        "effect_mappings_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "effect_mappings": {
          "type": "array",
          "minItems": 21,
          "maxItems": 21,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "app",
              "ledger_version",
              "ledger_name",
              "accepted_path",
              "source_commit",
              "blob",
              "raw_sha256",
              "byte_count",
              "effect_classes"
            ],
            "properties": {
              "app": {
                "enum": [
                  "discordos",
                  "mazer"
                ]
              },
              "ledger_version": {
                "type": "string",
                "pattern": "^[0-9]{14}$"
              },
              "ledger_name": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*$"
              },
              "accepted_path": {
                "type": "string",
                "pattern": "^supabase/migrations/[0-9]{14}_[a-z0-9_]+\\.sql$"
              },
              "source_commit": {
                "type": "string",
                "pattern": "^[0-9a-f]{40}$"
              },
              "blob": {
                "type": "string",
                "pattern": "^[0-9a-f]{40}$"
              },
              "raw_sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "byte_count": {
                "type": "integer",
                "minimum": 0
              },
              "effect_classes": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "enum": [
                    "relations",
                    "functions",
                    "policies",
                    "triggers",
                    "indexes",
                    "extensions",
                    "scheduler",
                    "held_functions",
                    "held_data_effects",
                    "held_dynamic_effects",
                    "acls",
                    "provider_ledger",
                    "terminal_catalog"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
