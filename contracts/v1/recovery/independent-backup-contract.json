  "receipt_contract": {
    "canonical_serialization": "lexicographic_object_keys_array_order_preserved_two_space_json_lf",
    "digest_algorithm": "SHA-256",
    "aggregate_only": true,
    "accepted_exports_authentication": {
      "required": true,
      "verification_boundary": "pinned_ed25519_signature",
      "subject_digest": "accepted_exports_evidence_without_verification_result",
      "required_result_status": "VERIFIED",
      "signature_domain": "fawxzzy-platform:accepted-exports-authentication:v1",
      "trust_anchor": {
        "status": "BLOCKED",
        "algorithm": "Ed25519",
        "key_id": "UNKNOWN",
        "verifier_reference": "UNKNOWN",
        "public_key_spki_base64": null,
        "public_key_spki_sha256": null
      }
    },
    "execution_gate_authentication": {
      "required": true,
      "verification_boundary": "pinned_ed25519_signature",
      "trust_anchor_source": "receipt_contract.accepted_exports_authentication.trust_anchor",
      "required_result_status": "VERIFIED",
      "signature_domain": "fawxzzy-platform:execution-gate-admission:v1",
      "maximum_age_seconds": 28800,
      "binding_class": "predeclared_receipt_export_source_state",
      "strictly_before_execution_boundary": true,
      "admission_policy": {
        "version": "1.0.0",
        "backup_current": [
          {
            "gate_id": "backup_generation_or_upload",
            "gate_version": "1.0.0",
            "scope": "backup_receipt"
          }
        ],
        "restore_rehearsed": [
          {
            "gate_id": "backup_generation_or_upload",
            "gate_version": "1.0.0",
            "scope": "backup_receipt"
          },
          {
            "gate_id": "restore_rehearsal",
            "gate_version": "1.0.0",
            "scope": "restore_receipt"
          }
        ]
      }
    },
    "restore_outcome_authentication": {
      "required": true,
      "verification_boundary": "pinned_ed25519_signature",
      "trust_anchor_source": "receipt_contract.accepted_exports_authentication.trust_anchor",
      "required_result_status": "VERIFIED",
      "signature_domain": "fawxzzy-platform:restore-outcome-attestation:v1",
      "maximum_age_seconds": 28800,
      "binding_class": "admitted_pre_restore_plan_and_final_outcome"
    },
    "storage_inventory_authentication": {
      "required": true,
      "verification_boundary": "pinned_ed25519_signature",
      "trust_anchor_source": "receipt_contract.accepted_exports_authentication.trust_anchor",
